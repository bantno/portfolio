---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
const sorted = projects.sort((a, b) => a.data.order - b.data.order);

const statusClass: Record<string, string> = {
  Active: "active",
  Complete: "complete",
  "In Development": "dev",
};
---

<Base>
  <Nav />
  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="readout">
        <span>33.7756°N 84.3963°W</span>
        <span>SYS:NOMINAL</span>
        <span>STATUS:ACTIVE</span>
      </div>

      <div class="hero-inner container">
        <div class="hero-image">
          <img src="/images/hero.jpg" alt="Brian Epstein with hardware" />
        </div>
        <p class="hero-tag">ROBOTICS & CONTROLS · PhD CANDIDATE</p>
        <h1 class="hero-name">Brian Epstein</h1>
        <p class="hero-role">
          PhD candidate building robotic systems that bridge the gap between simulation and the real world — from solar-powered seaplanes to combat robots.
        </p>
      </div>
    </section>

    <!-- Project Grid -->
    <section class="projects">
      <div class="container">
        <h2 class="section-label">// SYSTEMS</h2>
        <div class="project-grid">
          {sorted.map((project, i) => {
            const d = project.data;
            const isBrief = d.tier === "brief";
            const isProminent = d.tier === "flagship" || d.tier === "featured";
            const href = isBrief ? undefined : `/projects/${project.id.replace(/\.mdx?$/, "")}`;
            const Tag = isBrief ? "div" : "a";

            return (
              <Tag
                href={href}
                class:list={[
                  "card",
                  `tier-${d.tier}`,
                  { "card-brief": isBrief, "card-prominent": isProminent },
                ]}
                style={`animation-delay: ${i * 0.08}s`}
              >
                {/* Media area */}
                <div class="card-media">
                  {d.video ? (
                    <iframe
                      src={d.video}
                      title={d.title}
                      frameborder="0"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                      allowfullscreen
                      loading="lazy"
                    />
                  ) : (
                    <div class="media-placeholder">
                      <span class="placeholder-icon">⬡</span>
                      <span class="placeholder-text">{d.domain}</span>
                    </div>
                  )}
                </div>

                {/* Card body */}
                <div class="card-body">
                  <div class="card-header">
                    <span class={`status-badge ${statusClass[d.status]}`}>{d.status}</span>
                    <span class="domain-label">{d.domain}</span>
                    {isBrief && <span class="brief-label">Ongoing Research</span>}
                  </div>
                  <h3 class="card-title">{d.title}</h3>
                  {isBrief && <p class="card-date">{d.date_range}</p>}
                  <p class="card-desc">{d.summary}</p>
                  <div class="metrics">
                    {d.metrics.map((m) => (
                      <div class="metric">
                        <span class="metric-value">{m.value}</span>
                        <span class="metric-label">{m.label}</span>
                      </div>
                    ))}
                  </div>
                  <div class="card-tags">
                    {d.tags.map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                </div>
              </Tag>
            );
          })}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  /* ── Hero ──────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    padding-top: 56px;
    overflow: hidden;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(232, 197, 71, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(232, 197, 71, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .readout {
    position: absolute;
    top: 72px;
    right: var(--space-lg);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
    opacity: 0.6;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  .hero-image {
    width: 100%;
    max-height: 400px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--space-xl);
    border: 1px solid var(--color-border);
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-accent);
    letter-spacing: 0.2em;
    margin-bottom: var(--space-md);
  }

  .hero-name {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 800;
    color: var(--color-text-bright);
    line-height: 1.1;
    margin-bottom: var(--space-md);
  }

  .hero-role {
    font-size: 1.1rem;
    color: var(--color-text);
    max-width: 700px;
    line-height: 1.6;
  }

  /* ── Projects Section ──────────────────────────────────── */
  .projects {
    padding: var(--space-2xl) 0;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.15em;
    margin-bottom: var(--space-lg);
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: var(--space-lg);
  }

  /* Prominent cards span wider */
  .card-prominent {
    grid-column: span 1;
  }

  /* Card styles */
  .card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s;
    display: block;
    text-decoration: none;
    color: inherit;
  }

  a.card:hover {
    border-color: var(--color-border-bright);
    transform: translateY(-2px);
  }

  .card-brief {
    opacity: 0.75;
    cursor: default;
  }
  .card-brief:hover {
    transform: none;
    border-color: var(--color-border);
  }

  /* Card media */
  .card-media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-bg-raised);
    border-bottom: 1px solid var(--color-border);
  }
  .card-media iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .media-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    color: var(--color-text-muted);
  }
  .placeholder-icon {
    font-size: 2rem;
    opacity: 0.3;
  }
  .placeholder-text {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.4;
  }

  /* Card body */
  .card-body {
    padding: var(--space-lg);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
    flex-wrap: wrap;
  }

  .status-badge {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 2px 8px;
    border-radius: 3px;
  }
  .status-badge.active {
    background: rgba(71, 232, 120, 0.1);
    color: var(--color-status-active);
    border: 1px solid rgba(71, 232, 120, 0.25);
  }
  .status-badge.complete {
    background: rgba(71, 136, 232, 0.1);
    color: var(--color-status-complete);
    border: 1px solid rgba(71, 136, 232, 0.25);
  }
  .status-badge.dev {
    background: rgba(232, 166, 71, 0.1);
    color: var(--color-status-dev);
    border: 1px solid rgba(232, 166, 71, 0.25);
  }

  .domain-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .brief-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: var(--color-status-dev);
    background: rgba(232, 166, 71, 0.1);
    border: 1px solid rgba(232, 166, 71, 0.2);
    padding: 1px 6px;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-bright);
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }

  .card-date {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .card-desc {
    font-size: 0.9rem;
    color: var(--color-text);
    margin-bottom: var(--space-md);
    line-height: 1.6;
  }

  .metrics {
    display: flex;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
    padding: var(--space-sm) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .metric {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .metric-value {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-accent);
  }
  .metric-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-muted);
    background: var(--color-bg-raised);
    border: 1px solid var(--color-border);
    padding: 2px 8px;
    border-radius: 3px;
  }

  @media (max-width: 600px) {
    .readout {
      display: none;
    }
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
