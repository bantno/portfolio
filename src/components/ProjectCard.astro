---
interface Props {
  title: string;
  status: "Active" | "Complete" | "In Development";
  domain: string;
  description: string;
  tags: string[];
  metrics: { label: string; value: string }[];
  photo?: string;
  video?: string;
  cad_embed?: string;
  paper_url?: string;
  conference?: string;
  index: number;
}

const {
  title,
  status,
  domain,
  description,
  tags,
  metrics,
  photo,
  video,
  cad_embed,
  paper_url,
  conference,
  index,
} = Astro.props;

const statusClass = {
  Active: "active",
  Complete: "complete",
  "In Development": "dev",
}[status];
---

<article class="card fade-in" style={`animation-delay: ${index * 0.1}s`}>
  <!-- Media slot — placeholder or actual content -->
  <div class="card-media">
    {photo ? (
      <!-- Replace src with actual image path in public/ -->
      <img src={`/${photo}`} alt={title} loading="lazy" />
    ) : video ? (
      <!--
        VIDEO EMBED: Replace the src with your YouTube embed URL.
        Example: src="https://www.youtube.com/embed/VIDEO_ID"
      -->
      <iframe
        src={video}
        title={title}
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      />
    ) : cad_embed ? (
      <!--
        CAD EMBED: Replace the src with your Onshape or GrabCAD embed URL.
        Example: src="https://cad.onshape.com/documents/.../e/...?mode=render"
      -->
      <iframe
        src={cad_embed}
        title={`${title} — 3D Model`}
        frameborder="0"
        loading="lazy"
      />
    ) : (
      <!--
        PLACEHOLDER: This div is shown when no media is provided.
        To add media, set photo, video, or cad_embed in the project's .yaml file.
      -->
      <div class="media-placeholder">
        <span class="placeholder-icon">⬡</span>
        <span class="placeholder-text">{domain}</span>
      </div>
    )}
  </div>

  <!-- Card header -->
  <div class="card-body">
    <div class="card-header">
      <span class={`status-badge ${statusClass}`}>{status}</span>
      <span class="domain-label">{domain}</span>
    </div>

    <h3 class="card-title">{title}</h3>
    <p class="card-desc">{description}</p>

    <!-- Metrics strip -->
    <div class="metrics">
      {metrics.map((m) => (
        <div class="metric">
          <span class="metric-value">{m.value}</span>
          <span class="metric-label">{m.label}</span>
        </div>
      ))}
    </div>

    <!-- Tags -->
    <div class="card-tags">
      {tags.map((tag) => (
        <span class="tag">{tag}</span>
      ))}
    </div>

    <!-- Links -->
    {(paper_url || conference) && (
      <div class="card-links">
        {paper_url && (
          <a href={paper_url} target="_blank" rel="noopener noreferrer" class="card-link">
            Paper ↗
          </a>
        )}
        {conference && <span class="conference">{conference}</span>}
      </div>
    )}
  </div>
</article>

<style>
  .card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s;
  }
  .card:hover {
    border-color: var(--color-border-bright);
    transform: translateY(-2px);
  }

  /* ── Media area ──────────────────────────────────────────── */
  .card-media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-bg-raised);
    border-bottom: 1px solid var(--color-border);
  }
  .card-media img,
  .card-media iframe {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .media-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    color: var(--color-text-muted);
  }
  .placeholder-icon {
    font-size: 2rem;
    opacity: 0.3;
  }
  .placeholder-text {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.4;
  }

  /* ── Card body ───────────────────────────────────────────── */
  .card-body {
    padding: var(--space-lg);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .status-badge {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 2px 8px;
    border-radius: 3px;
  }
  .status-badge.active {
    background: rgba(71, 232, 120, 0.1);
    color: var(--color-status-active);
    border: 1px solid rgba(71, 232, 120, 0.25);
  }
  .status-badge.complete {
    background: rgba(71, 136, 232, 0.1);
    color: var(--color-status-complete);
    border: 1px solid rgba(71, 136, 232, 0.25);
  }
  .status-badge.dev {
    background: rgba(232, 166, 71, 0.1);
    color: var(--color-status-dev);
    border: 1px solid rgba(232, 166, 71, 0.25);
  }

  .domain-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-bright);
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }

  .card-desc {
    font-size: 0.9rem;
    color: var(--color-text);
    margin-bottom: var(--space-md);
    line-height: 1.6;
  }

  /* ── Metrics ─────────────────────────────────────────────── */
  .metrics {
    display: flex;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
    padding: var(--space-sm) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .metric {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .metric-value {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .metric-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* ── Tags ────────────────────────────────────────────────── */
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-md);
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-muted);
    background: var(--color-bg-raised);
    border: 1px solid var(--color-border);
    padding: 2px 8px;
    border-radius: 3px;
  }

  /* ── Links ───────────────────────────────────────────────── */
  .card-links {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .card-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .conference {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
  }
</style>
