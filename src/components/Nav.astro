---
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
const navProjects = projects
  .filter((p) => p.data.tier !== "brief")
  .sort((a, b) => a.data.order - b.data.order);
---

<nav class="nav">
  <div class="nav-inner container">
    <a href="/" class="nav-logo">B://EPSTEIN</a>

    <!-- Desktop links -->
    <div class="nav-links">
      <a href="/">Home</a>
      <div class="nav-dropdown">
        <button class="nav-dropdown-trigger" aria-expanded="false" aria-haspopup="true">
          Projects <span class="dropdown-arrow">▾</span>
        </button>
        <div class="dropdown-panel">
          {navProjects.map((p) => (
            <a href={`/projects/${p.id.replace(/\.mdx?$/, "")}`} class="dropdown-item">
              <span class="dropdown-title">{p.data.title}</span>
              <span class="dropdown-domain">{p.data.domain}</span>
            </a>
          ))}
        </div>
      </div>
      <a href="/career">Career</a>
      <a href="/about">About</a>
    </div>

    <!-- Mobile hamburger -->
    <button class="hamburger" aria-label="Toggle navigation" aria-expanded="false">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu">
    <a href="/">Home</a>
    <div class="mobile-section-label">Projects</div>
    {navProjects.map((p) => (
      <a href={`/projects/${p.id.replace(/\.mdx?$/, "")}`} class="mobile-project-link">
        {p.data.title}
      </a>
    ))}
    <a href="/career">Career</a>
    <a href="/about">About</a>
  </div>
</nav>

<script>
  const hamburger = document.querySelector('.hamburger');
  const nav = document.querySelector('.nav');
  if (hamburger && nav) {
    hamburger.addEventListener('click', () => {
      const isOpen = nav.classList.toggle('nav-open');
      hamburger.setAttribute('aria-expanded', String(isOpen));
    });
  }
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 14, 26, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .nav-logo {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.05em;
  }
  .nav-logo:hover {
    color: var(--color-accent);
  }

  /* Desktop links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .nav-links > a {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: color 0.2s;
  }
  .nav-links > a:hover {
    color: var(--color-text-bright);
  }

  /* Dropdown */
  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown-trigger {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .nav-dropdown-trigger:hover {
    color: var(--color-text-bright);
  }

  .dropdown-arrow {
    font-size: 0.6rem;
    transition: transform 0.2s;
  }

  .dropdown-panel {
    position: absolute;
    top: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 280px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-sm);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s, visibility 0.2s;
  }

  .nav-dropdown:hover .dropdown-panel,
  .nav-dropdown:focus-within .dropdown-panel {
    opacity: 1;
    visibility: visible;
  }
  .nav-dropdown:hover .dropdown-arrow {
    transform: rotate(180deg);
  }

  .dropdown-item {
    display: block;
    padding: 0.6rem 0.75rem;
    border-radius: var(--radius);
    transition: background 0.15s;
  }
  .dropdown-item:hover {
    background: var(--color-bg-card-hover);
  }

  .dropdown-title {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-bright);
  }
  .dropdown-item:hover .dropdown-title {
    color: var(--color-accent);
  }

  .dropdown-domain {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 2px;
  }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
    background: none;
    border: none;
    cursor: pointer;
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text-muted);
    border-radius: 1px;
    transition: all 0.3s;
  }

  /* Mobile menu */
  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 0 var(--space-lg) var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .mobile-menu a {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text);
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: color 0.2s;
  }
  .mobile-menu a:hover {
    color: var(--color-accent);
  }

  .mobile-section-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    padding: 0.75rem 0 0.25rem;
  }

  .mobile-project-link {
    font-size: 0.8rem !important;
    text-transform: none !important;
    padding-left: var(--space-md) !important;
    color: var(--color-text-muted) !important;
  }

  /* Mobile open state */
  .nav-open .mobile-menu {
    display: flex;
  }
  .nav-open .hamburger-line:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }
  .nav-open .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .nav-open .hamburger-line:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }
    .hamburger {
      display: flex;
    }
  }
</style>
