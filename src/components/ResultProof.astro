---
interface Props {
  metrics: { metric: string; context: string; href?: string }[];
}

const { metrics } = Astro.props;
---

<div class="result-proof">
  {metrics.map((m) => (
    m.href ? (
      <a href={m.href} target="_blank" rel="noopener noreferrer" class="proof-block proof-link">
        <div class="proof-metric">{m.metric}</div>
        <div class="proof-context">{m.context}</div>
      </a>
    ) : (
      <div class="proof-block">
        <div class="proof-metric">{m.metric}</div>
        <div class="proof-context">{m.context}</div>
      </div>
    )
  ))}
</div>

<style>
  .result-proof {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-md);
    margin: var(--space-xl) 0;
  }

  .proof-block {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg) var(--space-md);
    text-align: center;
  }

  .proof-metric {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1.3;
    margin-bottom: var(--space-sm);
  }

  .proof-context {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .proof-link {
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
    cursor: pointer;
  }

  .proof-link:hover {
    border-color: var(--color-accent);
    background: rgba(71, 232, 120, 0.04);
  }
</style>
