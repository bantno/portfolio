---
interface Props {
  src: string;
  alt: string;
  caption: string;
  number?: number;
  wide?: boolean;
}

const { src, alt, caption, number, wide = false } = Astro.props;
---

<figure class:list={["figure", { wide }]}>
  <div class="figure-media">
    <img src={src} alt={alt} loading="lazy" />
  </div>
  <figcaption>
    {number !== undefined && <span class="figure-number">Figure {number}</span>}
    {caption}
  </figcaption>
</figure>

<style>
  .figure {
    margin: var(--space-lg) 0;
  }

  .figure.wide {
    margin-inline: calc(-1 * var(--space-lg));
  }

  .figure-media {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-bg-raised);
  }

  .figure-media img {
    width: 100%;
    height: auto;
    display: block;
  }

  figcaption {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
    line-height: 1.5;
  }

  .figure-number {
    color: var(--color-accent);
    font-weight: 600;
    margin-right: var(--space-sm);
  }

  .figure-number::after {
    content: " —";
  }
</style>
