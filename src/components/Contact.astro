---
// Contact section — email, LinkedIn, GitHub, resume
---

<section id="contact" class="contact">
  <div class="container">
    <h2 class="section-label">// CONTACT</h2>
    <p class="contact-prompt">
      Open to research collaborations, industry partnerships, and interesting
      problems. Reach out through any channel below.
    </p>
    <div class="contact-grid">
      <a href="mailto:bepstein@gatech.edu" class="contact-card">
        <span class="contact-icon">@</span>
        <span class="contact-type">EMAIL</span>
        <span class="contact-value">bepstein@gatech.edu</span>
      </a>

      <!-- Replace # with your actual LinkedIn URL -->
      <a
        href="https://linkedin.com/in/"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-card"
      >
        <span class="contact-icon">in</span>
        <span class="contact-type">LINKEDIN</span>
        <span class="contact-value">linkedin.com/in/...</span>
      </a>

      <!-- Replace # with your actual GitHub URL -->
      <a
        href="https://github.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-card"
      >
        <span class="contact-icon">&gt;_</span>
        <span class="contact-type">GITHUB</span>
        <span class="contact-value">github.com/...</span>
      </a>

      <!-- Place your resume PDF at public/resume.pdf -->
      <a href="/resume.pdf" class="contact-card">
        <span class="contact-icon">&#9744;</span>
        <span class="contact-type">RESUME</span>
        <span class="contact-value">Download PDF</span>
      </a>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="container">
    <span class="footer-text">&copy; 2026 Brian Epstein · Georgia Institute of Technology</span>
  </div>
</footer>

<style>
  .contact {
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--color-border);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.15em;
    margin-bottom: var(--space-md);
  }

  .contact-prompt {
    font-size: 1rem;
    color: var(--color-text);
    margin-bottom: var(--space-xl);
    max-width: 500px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-md);
  }

  .contact-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: 4px;
    transition: border-color 0.2s, transform 0.2s;
    text-decoration: none;
  }
  .contact-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .contact-icon {
    font-family: var(--font-mono);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .contact-type {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .contact-value {
    font-size: 0.85rem;
    color: var(--color-text-bright);
  }

  /* ── Footer ──────────────────────────────────────────────── */
  .footer {
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--color-border);
  }

  .footer-text {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
  }
</style>
